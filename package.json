{
  "name": "fiber-wallet",
  "version": "0.1.0",
  "private": false,
  "description": "Desktop wallet and control panel for Fiber Network Node.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/desktop"
  ],
  "scripts": {
    "docs:milestone0": "node scripts/generate-milestone-0-docs.mjs",
    "smoke:ckb-health": "node scripts/ckb-health-smoke.mjs",
    "smoke:fiber-rpc": "node scripts/fiber-rpc-smoke.mjs",
    "dev": "npm --workspace apps/desktop run tauri:dev",
    "tauri:dev": "npm --workspace apps/desktop run tauri:dev",
    "tauri:build": "npm --workspace apps/desktop run tauri:build",
    "build:web": "npm --workspace apps/desktop run build:web",
    "lint": "npm --workspace apps/desktop run lint",
    "test": "npm --workspace apps/desktop run test"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=11"
  }
}
