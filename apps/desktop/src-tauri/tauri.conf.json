{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Fiber Wallet",
  "version": "0.1.0",
  "identifier": "com.fiberwallet.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fiber Wallet",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}

